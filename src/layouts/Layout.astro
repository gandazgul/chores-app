---
import '@unocss/reset/tailwind.css';
import 'uno.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chores App</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <meta name="theme-color" content="#ffffff" />
    <meta name="description" content="Manage household chores with constant reminders." />
    <!-- manifest.json to be added in future phase -->
  </head>
  <body class="bg-gray-100 text-gray-900 font-sans min-h-screen">
    <header class="bg-blue-600 text-white p-4 shadow-md">
      <div class="container mx-auto max-w-4xl flex justify-between items-center">
        <h1 class="text-2xl font-bold">Chores</h1>
      </div>
    </header>
    
    <main class="container mx-auto max-w-4xl p-4 mt-4">
      <slot />
    </main>
    
    <footer class="text-center text-gray-500 mt-12 pb-8">
      <p>&copy; {new Date().getFullYear()} Chores App Astro Editon</p>
    </footer>
  </body>
</html>
